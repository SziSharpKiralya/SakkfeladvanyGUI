<Window x:Class="SakkfeladvanyGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SakkfeladvanyGUI"
        mc:Ignorable="d"
        Background="Transparent"
		ResizeMode="NoResize"
		WindowStyle="None"
		Height="460"
		Width="335"
		Title="">

	<Window.Resources>
		<SolidColorBrush x:Key="Main"
						 Color="Azure" />
		<SolidColorBrush x:Key="Buttons"
						 Color="AntiqueWhite" />
		<SolidColorBrush x:Key="Text"
						 Color="Black" />
		<FontFamily x:Key="MainFont">Bahnschrift</FontFamily>
	</Window.Resources>

	<Border Background="{StaticResource Main}"
		MouseLeftButtonDown="background_drag">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="40" />
				<RowDefinition Height="0.3*" />
				<RowDefinition Height="0.3*" />
				<RowDefinition Height="2*" />
				<RowDefinition Height="0.3*" />
			</Grid.RowDefinitions>

			<Grid Background="Transparent"
			  Grid.Row="0"
			  Margin="5">
				<Label Content="Sakkfeladvány"
				   Width="200"
				   Height="30"
				   FontSize="18"
				   FontWeight="Bold"
				   Margin="0,0,0,0"
				   Foreground="{StaticResource Text}"
				   FontFamily="{StaticResource MainFont}"
				   VerticalAlignment="Center"
				   HorizontalAlignment="Left"
				   VerticalContentAlignment="Center"
				   HorizontalContentAlignment="Left" />
				<Button Content="❌"
					Width="36"
					Height="24"
					FontSize="12"
					Margin="0,0,0,0"
					Background="RosyBrown"
					Foreground="White"
					BorderThickness="0"
					VerticalAlignment="Center"
					HorizontalAlignment="Right"
					Click="btnClose_Click" />
			</Grid>
			<Grid Grid.Row="1"
				Margin="5">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="2.5*" />
					<ColumnDefinition Width="0.4*" />
					<ColumnDefinition Width="0.4*" />
				</Grid.ColumnDefinitions>

				<Label 
					Grid.Row="0"
					Grid.Column="0"
					Content="Sakktábla mérete [sor x oszlop]:"
					FontSize="16"
					FontWeight="Bold"
					Margin="0,0,0,0"
					Foreground="{StaticResource Text}"
					FontFamily="{StaticResource MainFont}"
					VerticalAlignment="Center"
					HorizontalAlignment="Left"
					VerticalContentAlignment="Center"
					HorizontalContentAlignment="Left" />

				<ComboBox x:Name="cb_row"
					Grid.Row="0"
					Grid.Column="1"
					FontSize="16"
					Background="{StaticResource Buttons}"
					Foreground="{StaticResource Text}"
					FontFamily="{StaticResource MainFont}"
					BorderThickness="0"
					VerticalAlignment="Stretch"
					HorizontalAlignment="Stretch"
					Margin="5" />
				<ComboBox  x:Name="cb_col"
					Grid.Row="0"
					Grid.Column="2"
					FontSize="16"
					Background="{StaticResource Buttons}"
					Foreground="{StaticResource Text}"
					FontFamily="{StaticResource MainFont}"
					BorderThickness="0"
					VerticalAlignment="Stretch"
					HorizontalAlignment="Stretch"
					Margin="5" />
			</Grid>
			<Button Grid.Row="2"
				Grid.Column="0"
				Content="Tábla létrehozása"
				FontSize="16"
				Background="{StaticResource Buttons}"
				Foreground="{StaticResource Text}"
				FontFamily="{StaticResource MainFont}"
				BorderThickness="0"
				VerticalAlignment="Stretch"
				HorizontalAlignment="Stretch"
				Margin="5"
				Click="btnCreate_Click">
			</Button>
			<Grid x:Name="grid_tabla"
			  Grid.Row="3"
			  Margin="5">
				<Grid.RowDefinitions>
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
			</Grid>
			<Label 
				Grid.Row="4"
				Grid.Column="0"
				Content="Minden sorban helyezzen el egy királynőt!"
				FontSize="16"
				FontWeight="Bold"
				Margin="0,0,0,0"
				Foreground="{StaticResource Text}"
				FontFamily="{StaticResource MainFont}"
				VerticalAlignment="Center"
				HorizontalAlignment="Center"
				VerticalContentAlignment="Center"
				HorizontalContentAlignment="Center" />
		</Grid>
	</Border>
</Window>
